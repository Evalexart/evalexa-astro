---
const {
  title,
  description,
  cards = [],
  previousLabel = "Précédent",
  nextLabel = "Suivant",
} = Astro.props;
---

<section class="card-rail-section" data-card-rail-section>
  <div class="card-rail-heading">
    <h2>{title}</h2>
    {description && <p>{description}</p>}
  </div>

  <div class="card-rail-frame">
    <button
      type="button"
      class="card-rail-arrow card-rail-arrow-prev"
      data-card-rail-prev
      aria-label={previousLabel}
    >
      <span aria-hidden="true">‹</span>
    </button>

    <div class="card-rail-track" data-card-rail-track>
      {
        cards.map((card) => (
          <a class="card-rail-card" href={card.href}>
            {card.kicker && (
              <span class="card-rail-kicker">{card.kicker}</span>
            )}

            <strong class="card-rail-title">{card.title}</strong>

            {card.description && (
              <span class="card-rail-description">{card.description}</span>
            )}
          </a>
        ))
      }
    </div>

    <button
      type="button"
      class="card-rail-arrow card-rail-arrow-next"
      data-card-rail-next
      aria-label={nextLabel}
    >
      <span aria-hidden="true">›</span>
    </button>
  </div>
</section>

<script>
  const railSections = document.querySelectorAll("[data-card-rail-section]");

  railSections.forEach((section) => {
    const track = section.querySelector("[data-card-rail-track]");
    const previousButton = section.querySelector("[data-card-rail-prev]");
    const nextButton = section.querySelector("[data-card-rail-next]");

    if (!track || !previousButton || !nextButton) return;

    const getScrollStep = () => {
      const firstCard = track.querySelector(".card-rail-card");

      if (!firstCard) return 320;

      const cardWidth = firstCard.getBoundingClientRect().width;
      const trackStyle = window.getComputedStyle(track);
      const gap = parseFloat(trackStyle.columnGap || trackStyle.gap || "0");

      return cardWidth + gap;
    };

    const updateArrowState = () => {
      const maxScrollLeft = track.scrollWidth - track.clientWidth;
      const currentScrollLeft = track.scrollLeft;
      const threshold = 4;

      const isAtStart = currentScrollLeft <= threshold;
      const isAtEnd = currentScrollLeft >= maxScrollLeft - threshold;

      previousButton.classList.toggle("is-muted", isAtStart);
      nextButton.classList.toggle("is-muted", isAtEnd);

      previousButton.setAttribute("aria-disabled", String(isAtStart));
      nextButton.setAttribute("aria-disabled", String(isAtEnd));
    };

    previousButton.addEventListener("click", () => {
      track.scrollBy({
        left: -getScrollStep(),
        behavior: "smooth",
      });
    });

    nextButton.addEventListener("click", () => {
      track.scrollBy({
        left: getScrollStep(),
        behavior: "smooth",
      });
    });

    track.addEventListener("scroll", updateArrowState, { passive: true });
    window.addEventListener("resize", updateArrowState);

    updateArrowState();
  });
</script>
---
const title = "Evalexa";
const description = "Redirection vers la version linguistique du site Evalexa.";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/png" href="/favicon.png" />

    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem("evalexa-theme");
        const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        const theme = savedTheme || (prefersLight ? "light" : "dark");

        document.documentElement.setAttribute("data-theme", theme);

        const browserLang = navigator.language || navigator.userLanguage || "";
        const target = browserLang.toLowerCase().startsWith("fr") ? "/fr/" : "/en/";

        window.location.replace(target);
      })();
    </script>
  </head>

  <body>
    <noscript>
      <p>
        JavaScript est nécessaire pour la redirection automatique.
        <a href="/fr/">Version française</a> ·
        <a href="/en/">English version</a>
      </p>
    </noscript>
  </body>
</html>
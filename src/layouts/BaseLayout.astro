---
import Header from "../components/Header.astro";

const {
  lang = "fr",
  area = "main",
  pageId = "home",
  title = "Evalexa",
  description = "Site principal du projet Evalexa.",
  frHref = "/fr/",
  enHref = "/en/",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="/assets/css/main.css" />

    <script is:inline>
      (() => {
        const savedTheme = localStorage.getItem("evalexa-theme");
        const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        const theme = savedTheme || (prefersLight ? "light" : "dark");

        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>

  <body data-area={area} data-page={pageId}>
    <a class="skip-link" href="#main">Aller au contenu</a>

    <Header lang={lang} frHref={frHref} enHref={enHref} />

    <main id="main">
      <slot />
    </main>

    <script src="/assets/js/theme.js" defer></script>
    <script src="/assets/js/language-switch.js" defer></script>

    <script is:inline>
      window.addEventListener("DOMContentLoaded", () => {
        if (window.EvalexaTheme) {
          window.EvalexaTheme.applyTheme(window.EvalexaTheme.getPreferredTheme());
          window.EvalexaTheme.initThemeControls();
        }
      });
    </script>
  </body>
</html>